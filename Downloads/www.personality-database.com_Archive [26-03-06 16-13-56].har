ions\":[],\"own_reactions\":[],\"reaction_counts\":{},\"reaction_scores\":{},\"reply_count\":0,\"deleted_reply_count\":0,\"cid\":\"messaging:5518018-68527232385668\",\"created_at\":\"2026-03-04T16:35:27.639738Z\",\"updated_at\":\"2026-03-04T16:35:27.639738Z\",\"shadowed\":false,\"mentioned_users\":[],\"mentioned_channel\":false,\"mentioned_here\":false,\"silent\":false,\"pinned\":false,\"pinned_at\":null,\"pinned_by\":null,\"pin_expires\":null,\"restricted_visibility\":[]},\"cid\":\"messaging:5518018-68527232385668\",\"created_at\":\"2026-03-04T16:37:18.147715Z\",\"updated_at\":\"2026-03-04T16:37:18.147715Z\",\"shadowed\":false,\"mentioned_users\":[],\"mentioned_channel\":false,\"mentioned_here\":false,\"silent\":false,\"pinned\":false,\"pinned_at\":null,\"pinned_by\":null,\"pin_expires\":null,\"restricted_visibility\":[]},{\"id\":\"c0d7f90a-b471-4fd4-9e3e-09a1223fe8c1\",\"text\":\"U know? Even if u do reincarnate tho thats unlikely, u still have to make the best out of this life regardless. U cant hope ur future loser self to have a good life for u and think that justifies not living to ur fullest in ur current life?\\nAm I tripping?\",\"html\":\"\\u003cp\\u003eU know? Even if u do reincarnate tho thats unlikely, u still have to make the best out of this life regardless. U cant hope ur future loser self to have a good life for u and think that justifies not living to ur fullest in ur current life?\\u003cbr/\\u003e\\nAm I tripping?\\u003c/p\\u003e\\n\",\"type\":\"regular\",\"user\":{\"id\":\"5518018\",\"name\":\"Askie?\",\"image\":\"https://static1.personalitydatabase.net/2/pdb-user-avatars-prod/4efab040/user_avatars/5518018/c0423555-5404-4817-ad41-14e32703d651_small.jpeg\",\"language\":\"en\",\"role\":\"user\",\"teams\":[],\"created_at\":\"2026-02-19T01:40:30.312107Z\",\"updated_at\":\"2026-03-04T16:33:32.940167Z\",\"banned\":false,\"online\":true,\"last_active\":\"2026-03-06T21:10:59.638072495Z\",\"blocked_user_ids\":[\"1351937\",\"4734444\",\"4762721\",\"5146206\