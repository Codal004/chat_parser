ersonality_type_id\":253,\"personality_type\":\"LFVE\"},{\"personality_type_id\":249,\"personality_type\":\"FLVE\"},{\"personality_type_id\":248,\"personality_type\":\"FVLE\"},{\"personality_type_id\":271,\"personality_type\":\"FEVL\"},{\"personality_type_id\":252,\"personality_type\":\"LVFE\"},{\"personality_type_id\":266,\"personality_type\":\"FLEV\"},{\"personality_type_id\":267,\"personality_type\":\"FELV\"},{\"personality_type_id\":258,\"personality_type\":\"ELFV\"},{\"personality_type_id\":259,\"personality_type\":\"EFLV\"},{\"personality_type_id\":254,\"personality_type\":\"EVFL\"},{\"personality_type_id\":255,\"personality_type\":\"EFVL\"},{\"personality_type_id\":251,\"personality_type\":\"ELVF\"},{\"personality_type_id\":270,\"personality_type\":\"FVEL\"},{\"personality_type_id\":250,\"personality_type\":\"EVLF\"}],\"9\":[{\"personality_type_id\":272,\"personality_type\":\"RCOAI\"},{\"personality_type_id\":273,\"personality_type\":\"RCOAN\"},{\"personality_type_id\":274,\"personality_type\":\"RLOAN\"},{\"personality_type_id\":275,\"personality_type\":\"RLOAI\"},{\"personality_type_id\":276,\"personality_type\":\"RLUAI\"},{\"personality_type_id\":277,\"personality_type\":\"RLUAN\"},{\"personality_type_id\":278,\"personality_type\":\"RCUAN\"},{\"personality_type_id\":279,\"personality_type\":\"RCUAI\"},{\"personality_type_id\":280,\"personality_type\":\"RCOEI\"},{\"personality_type_id\":281,\"personality_type\":\"RCOEN\"},{\"personality_type_id\":282,\"personality_type\":\"RLOEN\"},{\"personality_type_id\":283,\"personality_type\":\"RLOEI\"},{\"personality_type_id\":284,\"personality_type\":\"RLUEI\"},{\"personality_type_id\":285,\"personality_type\":\"RLUEN\"},{\"personality_type_id\":286,\"personality_type\":\"RCUEN\"},{\"personality_type_id\":287,\"personality_type\":\"RCUEI\"},{\"personality_type_id\":288,\"personality_type\":\"SCOAI\"},{\"personality_type_id\":289,\"personality_type\":\"SCOAN\"},{\"personality_type_id\":290,\"personality_type\":\"SLOAN\"},{\"personality_type_id\":291,\"personality_type\":\"SLOAI\"},{\"personality_type_id\":292,\"personality_type\":\"SLUAI\"},{\"personality_type_id\":293,\"personality_type\":\"SLUAN\"},{\"personality_type_id\":294,\"personality_type\":\"SCUAN\"},{\"personality_type_id\":295,\"personality_type\":\"SCUAI\"},{\"personality_type_id\":296,\"personality_type\":\"SCOEI\"},{\"personality_type_id\":297,\"personality_type\":\"SCOEN\"},{\"personality_type_id\":298,\"personality_type\":\"SLOEN\"},{\"personality_type_id\":299,\"personality_type\":\"SLOEI\"},{\"personality_type_id\":300,\"personality_type\":\"SLUEI\"},{\"personality_type_id\":301,\"personality_type\":\"SLUEN\"},{\"personality_type_id\":302,\"personality_type\":\"SCUEN\"},{\"personality_type_id\":303,\"personality_type\":\"SCUEI\"}]},\"pcategories\":[{\"property\":\"Celebrities\",\"property_id\":1,\"categories\":[{\"cat_id\":1,\"category\":\"Pop Culture\",\"description\":\"Explore the personality types of your favorite actors — from Hollywood stars to international icons.Find out which celebrities are ENFP, INFJ, or ENTJ, and see how their personalities compare across roles and careers.\"},{\"cat_id\":14,\"category\":\"Musician\",\"description\":\"Discover the MBTI and Enneagram of world-famous singers, songwriters, and musicians.Whether it’s a pop star, rock legend, or indie artist, explore how fans type their favorite performers.\"},{\"cat_id\":29,\"category\":\"Kpop\",\"description\":\"Find out the MBTI and Enneagram types of K‑Pop idols and stars — from BTS and BLACKPINK to newer groups and solo artists.See which members are introverts, feelers, or thinkers, and how their traits reflect their personalities.\"},{\"cat_id\":16,\"category\":\"The Arts\",\"description\":\"Discover personality types of well-known painters, authors, poets, designers, and comic artists.Find out if your favorite creative minds are INFP idealists, INTJ strategists, or ENFP visionaries — and explore how personality influences art, writing, and creative thinking.\"},{\"cat_id\":28,\"category\":\"Philosophy\",\"description\":\"Explore the personality types of major philosophers and deep thinkers throughout history — from Socrates to Nietzscheto Simone de Beauvoir.See how thinkers are typed as INTP, INFJ, INTJ, and more, and how their personality traits align with their ideas.\"},{\"cat_id\":21,\"category\":\"Science\",\"description\":\"See how famous scientists, inventors, and thinkers are typed by fans — including historical and modern-day innovators.Explore what personality types align with curiosity, logic, and creativity in science.\"},{\"cat_id\":5,\"category\":\"Sports\",\"description\":\"Discover the personality types of world-famous athletes — including footballers, basketball players, Olympians, tennis champions, and more.Find out which sports stars are INTJ planners, ESTP competitors, or ENFJ leaders, and how their personalities reflects their mindset, motivation, and performance.\"},{\"cat_id\":17,\"category\":\"Business\",\"description\":\"Discover the personality types of CEOs, founders, and entrepreneurs. Find out which business leaders are ENTJ visionaries, INTP thinkers, or ESTJ organizers.\"},{\"cat_id\":15,\"category\":\"Internet\",\"description\":\"Find out the personality types of YouTubers, streamers, TikTok stars, and KOLs from around the world.Whether you’re curious about a creator’s MBTI or want to know if your favorite online personality is ENFP, ISFJ, or INTJ — you’ll find fan-voted insights here.\"},{\"cat_id\":10,\"category\":\"Noteworthy\",\"description\":\"Explore the MBTI and Enneagram of noteworthy figures in journalism, law, and public service. From investigative reporters to top attorneys, find out how their personalities shape their impact.\"},{\"cat_id\":22,\"category\":\"Historical\",\"description\":\"Learn how famous people from history are typed using MBTI and Enneagram — from philosophers and monarchs to inventors and revolutionaries.Discover what made them tick, and how their traits may reflect INTJ, ENFP, or ISTJ personalities.\"},{\"cat_id\":18,\"category\":\"Religion\",\"description\":\"Explore how religious leaders and spiritual figures are typed using MBTI and Enneagram. From saints and prophets to modern voices, discover the traits they may share with INFJs, ENFPs, or INTJs.\"},{\"cat_id\":6,\"category\":\"Political\",\"description\":\"Find out the personality types of presidents, prime ministers, and political leaders around the world. Discover who’s an ENTJ strategist, INFJ idealist, or ISTP pragmatist, based on MBTI and Enneagram insights.\"}]},{\"property\":\"Characters\",\"property_id\":2,\"categories\":[{\"cat_id\":27,\"category\":\"Superheroes\",\"description\":\"Discover the MBTI and Enneagram types of your favorite superhero characters — from the Bat‑Family and Arrowverse to the Avengers, X‑Men, and more. Whether you're a fan of DC or Marvel, explore how these heroes rank by personality.\"},{\"cat_id\":3,\"category\":\"Movies\",\"description\":\"Explore the MBTI, Enneagram, and traits of characters from films like Harry Potter, Marvel, Disney, Star Wars, and more. Compare characters by type and see how they think and behave.\"},{\"cat_id\":2,\"category\":\"Television\",\"description\":\"Find out the MBTI and Enneagram types of characters from your favorite TV shows. From Netflix hits to HBO dramas, explore personality types for characters from Stranger Things, Game of Thrones, Breaking Bad, and more.See if they’re introverts, thinkers, or feelers — and compare traits across shows.\"},{\"cat_id\":8,\"category\":\"Anime \\u0026 Manga\",\"description\":\"Browse the MBTI and Enneagram of popular anime and manga characters. Whether it’s Naruto, Attack on Titan, Jujutsu Kaisen, or One Piece, you can find out who’s INTP, ENFP, or ISTJ — and how fans voted on their traits.Perfect for anime fans who love psychology and character analysis.\"},{\"cat_id\":11,\"category\":\"Gaming\",\"description\":\"See the MBTI and Enneagram types of video game characters from games like Genshin Impact, Final Fantasy, Zelda, Persona, and more.Find out which characters match your personality type, and compare traits like introversion, intuition, and decision-making styles across your favorite games.\"},{\"cat_id\":7,\"category\":\"Cartoons\",\"description\":\"Discover the personality types of cartoon characters from shows like Arcane, Avatar: The Last Airbender, Rick and Morty, and more.Explore how these characters rank in MBTI and Enneagram systems — from creative ENFPs to strategic INTJs.\"},{\"cat_id\":12,\"category\":\"Literature\",\"description\":\"Find out the MBTI and Enneagram of your favorite book characters — from Harry Potter and Pride \\u0026 Prejudice to Lord of the Rings.Whether they’re thinkers or feelers, introverts or leaders, explore how fictional characters in literature map to real-world personality types.\"},{\"cat_id\":9,\"category\":\"Comics\",\"description\":\"Discover the personality types of comic book characters outside the Marvel and DC universes — including indie comics, graphic novels, and international series.Find out which characters are INTP, ENFP, INFJ, and more, and explore how fans voted on their traits.\"},{\"cat_id\":26,\"category\":\"Web Comics\",\"description\":\"Explore the MBTI and Enneagram types of characters from Korean Webtoons and other digital comics. From Lore Olympus to Solo Leveling, see how readers type their favorite characters and what traits stand out.\"},{\"cat_id\":13,\"category\":\"Theatre\",\"description\":\"Discover the MBTI and Enneagram of classic and modern stage characters from plays and musicals — including Hamlet, Wicked, Les Misérables, Death of a Salesman, and more.See which theatre characters are introverts, feelers, or thinkers — and how personality theory brings dramatic roles to life.\"}]},{\"property\":\"Concepts\",\"property_id\":3,\"categories\":[{\"cat_id\":33,\"category\":\"Music\",\"description\":\"\"},{\"cat_id\":30,\"category\":\"Traits\",\"description\":\"\"},{\"cat_id\":35,\"category\":\"Culture\",\"description\":\"\"},{\"cat_id\":32,\"category\":\"Concepts\",\"description\":\"\"},{\"cat_id\":42,\"category\":\"Nature\",\"description\":\"\"},{\"cat_id\":31,\"category\":\"Plots \\u0026 Archetypes\",\"description\":\"\"},{\"cat_id\":34,\"category\":\"Franchises\",\"description\":\"\"},{\"cat_id\":36,\"category\":\"Theories\",\"description\":\"\"},{\"cat_id\":43,\"category\":\"Technology\",\"description\":\"\"},{\"cat_id\":37,\"category\":\"Polls (If you...)\",\"description\":\"\"},{\"cat_id\":38,\"category\":\"Your Experience\",\"description\":\"\"},{\"cat_id\":39,\"category\":\"Type Combo (Your Type)\",\"description\":\"\"},{\"cat_id\":40,\"category\":\"Ask Pdb\",\"description\":\"\"},{\"cat_id\":41,\"category\":\"PDB Community\",\"description\":\"\"}]}]}"
